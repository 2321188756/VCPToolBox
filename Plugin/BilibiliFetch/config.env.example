# ==========================================================
# BilibiliFetch 插件配置
# ==========================================================

# B站登录Cookie（可选，但获取字幕需要）
# 从浏览器开发者工具 → Network 标签 → 任意请求 → Cookie 字段复制
# 推荐至少包含: SESSDATA, bili_jct, DedeUserID, buvid3
BILIBILI_COOKIE=

# 字幕语言偏好 (ai-zh: AI中文字幕, zh-CN: 人工中文字幕, en: 英文字幕)
BILIBILI_SUB_LANG=ai-zh
